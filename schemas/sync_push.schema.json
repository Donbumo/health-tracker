{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/sync_push.schema.json",
  "title": "Mobile sync push request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "operations"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "batch_id": {"type": "string", "format": "uuid"},
    "operations": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["client_operation_id", "entity_type", "operation", "entity_id", "payload"],
        "properties": {
          "client_operation_id": {"type": "string", "format": "uuid"},
          "entity_type": {"type": "string", "minLength": 1, "maxLength": 40},
          "operation": {"enum": ["upsert", "delete", "transition"]},
          "entity_id": {"type": "string", "format": "uuid"},
          "base_revision": {"type": "integer", "minimum": 1},
          "payload": {"type": "object"}
        }
      }
    }
  }
}
