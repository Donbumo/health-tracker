{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/companion_negotiation.schema.json",
  "title": "Companion capability negotiation 1.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "protocol_versions", "workout_schema_versions", "result_schema_versions", "features", "metrics", "limits"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "protocol_versions": {"$ref": "#/$defs/versions"}, "workout_schema_versions": {"$ref": "#/$defs/versions"}, "result_schema_versions": {"$ref": "#/$defs/versions"},
    "features": {"type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "maxLength": 64}},
    "metrics": {"type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "maxLength": 64}},
    "limits": {"type": "object", "additionalProperties": false, "properties": {"max_payload_bytes": {"type": "integer", "minimum": 1}, "max_progress_events_per_workout": {"type": "integer", "minimum": 1}}},
    "base_revision": {"type": "integer", "minimum": 1}
  },
  "$defs": {"versions": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}}}
}
