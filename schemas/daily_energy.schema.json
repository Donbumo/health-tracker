{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/daily_energy.schema.json",
  "title": "Daily energy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "user_id", "source_type", "data"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "daily_energy"},
    "user_id": {"type": "integer", "minimum": 1},
    "source_type": {
      "type": "string",
      "enum": ["manual_generated", "uploaded", "device_sync"]
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "total_expenditure_kcal": {"type": "number", "minimum": 0, "maximum": 100000},
        "resting_expenditure_kcal": {"type": "number", "minimum": 0, "maximum": 100000},
        "active_expenditure_kcal": {"type": "number", "minimum": 0, "maximum": 100000},
        "steps": {"type": "integer", "minimum": 0, "maximum": 10000000},
        "distance_meters": {"type": "number", "minimum": 0, "maximum": 100000000},
        "source": {"type": "string", "minLength": 1, "maxLength": 32},
        "notes": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
