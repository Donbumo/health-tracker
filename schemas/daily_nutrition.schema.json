{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/daily_nutrition.schema.json",
  "title": "Daily nutrition (minimum)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "user_id", "source_type", "data"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "daily_nutrition"},
    "user_id": {"type": "integer", "minimum": 1},
    "source_type": {
      "type": "string",
      "enum": ["manual_generated", "uploaded", "device_sync"]
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "calories_kcal", "protein_g", "carbohydrate_g", "fat_g"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "calories_kcal": {"type": "number", "minimum": 0},
        "protein_g": {"type": "number", "minimum": 0},
        "carbohydrate_g": {"type": "number", "minimum": 0},
        "fat_g": {"type": "number", "minimum": 0},
        "notes": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
