{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/route.schema.json",
  "title": "Route",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "user_id", "source_type", "data"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "route"},
    "user_id": {"type": "integer", "minimum": 1},
    "source_type": {"type": "string", "enum": ["uploaded", "device_sync"]},
    "source_file_id": {"type": "integer", "minimum": 1},
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "route_type"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 255},
        "route_type": {"type": "string", "minLength": 1, "maxLength": 64},
        "distance_meters": {"type": "number", "minimum": 0},
        "elevation_gain_meters": {"type": "number", "minimum": 0},
        "elevation_loss_meters": {"type": "number", "minimum": 0},
        "bounds": {"type": "object", "additionalProperties": {"type": "number"}},
        "points": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lat", "lon"],
            "properties": {
              "timestamp": {"type": "string", "format": "date-time"},
              "lat": {"type": "number", "minimum": -90, "maximum": 90},
              "lon": {"type": "number", "minimum": -180, "maximum": 180},
              "elevation_meters": {"type": "number"},
              "distance_meters": {"type": "number", "minimum": 0}
            }
          }
        },
        "source_app": {"type": "string", "maxLength": 128},
        "warnings": {"type": "array", "items": {"type": "string", "maxLength": 500}},
        "notes": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
