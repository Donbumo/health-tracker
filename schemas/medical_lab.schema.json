{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/medical_lab.schema.json",
  "title": "Medical laboratory report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "type", "user_id", "source_type", "date", "markers"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "type": {"const": "medical_lab"},
    "user_id": {"type": "integer", "minimum": 1},
    "source_type": {
      "type": "string",
      "enum": ["manual_generated", "uploaded"]
    },
    "date": {"type": "string", "format": "date"},
    "laboratory_name": {"type": "string", "minLength": 1, "maxLength": 200},
    "doctor_name": {"type": "string", "minLength": 1, "maxLength": 200},
    "source": {"type": "string", "minLength": 1, "maxLength": 32},
    "notes": {"type": "string", "maxLength": 5000},
    "markers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/marker"}
    }
  },
  "$defs": {
    "marker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "unit"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 200},
        "code": {"type": "string", "minLength": 1, "maxLength": 100},
        "value": {
          "oneOf": [
            {"type": "number"},
            {"type": "string", "minLength": 1, "maxLength": 500}
          ]
        },
        "unit": {"type": "string", "minLength": 1, "maxLength": 100},
        "reference_min": {"type": "number"},
        "reference_max": {"type": "number"},
        "reference_text": {"type": "string", "minLength": 1, "maxLength": 500},
        "status": {
          "type": "string",
          "enum": ["low", "normal", "high", "unknown"]
        },
        "notes": {"type": "string", "maxLength": 2000}
      }
    }
  }
}
