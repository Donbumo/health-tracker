{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/food_product.schema.json",
  "title": "Health Tracker reusable food product",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "type", "user_id", "source_type", "data"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "type": {"const": "food_product"},
    "user_id": {"type": "integer", "minimum": 1},
    "source_type": {"enum": ["uploaded", "manual_generated", "converted", "system_generated", "synced_from_device"]},
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source"],
      "properties": {
        "name": {"type": "string", "maxLength": 200, "minLength": 1},
        "brand": {"type": ["string", "null"], "maxLength": 200},
        "serving_size_g": {"type": ["number", "null"], "minimum": 0},
        "serving_label": {"type": ["string", "null"], "maxLength": 64},
        "calories_per_100g": {"type": ["number", "null"], "minimum": 0},
        "protein_g_per_100g": {"type": ["number", "null"], "minimum": 0},
        "fat_g_per_100g": {"type": ["number", "null"], "minimum": 0},
        "carbs_g_per_100g": {"type": ["number", "null"], "minimum": 0},
        "net_carbs_g_per_100g": {"type": ["number", "null"], "minimum": 0},
        "fiber_g_per_100g": {"type": ["number", "null"], "minimum": 0},
        "sodium_mg_per_100g": {"type": ["number", "null"], "minimum": 0},
        "source": {"type": "string", "maxLength": 32, "minLength": 1},
        "notes": {"type": ["string", "null"]}
      }
    }
  }
}
