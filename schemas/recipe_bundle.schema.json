{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-tracker.local/schemas/recipe_bundle.schema.json",
  "title": "Health Tracker recipe bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "type", "recipes"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "type": { "const": "recipe_bundle" },
    "name": { "type": ["string", "null"], "maxLength": 200 },
    "user_id": { "type": "integer", "minimum": 1 },
    "source_type": {
      "enum": ["uploaded", "manual_generated", "converted", "system_generated", "synced_from_device"]
    },
    "recipes": {
      "type": "array",
      "items": { "$ref": "#/$defs/recipe" }
    }
  },
  "$defs": {
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "type", "name", "ingredients"],
      "properties": {
        "schema_version": { "const": "1.0" },
        "type": { "const": "recipe" },
        "user_id": { "type": "integer", "minimum": 1 },
        "source_type": {
          "enum": ["uploaded", "manual_generated", "converted", "system_generated", "synced_from_device"]
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": ["string", "null"] },
        "servings": { "type": "number", "exclusiveMinimum": 0 },
        "yield_weight_g": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "source": { "type": "string", "minLength": 1, "maxLength": 32 },
        "notes": { "type": ["string", "null"] },
        "ingredients": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["quantity_g"],
            "properties": {
              "food_product_id": { "type": "integer", "minimum": 1 },
              "food_product_name": { "type": "string", "minLength": 1, "maxLength": 200 },
              "food_product_brand": { "type": ["string", "null"], "maxLength": 200 },
              "quantity_g": { "type": "number", "exclusiveMinimum": 0 },
              "sort_order": { "type": "integer", "minimum": 1 },
              "notes": { "type": ["string", "null"] }
            },
            "oneOf": [
              { "required": ["food_product_id"] },
              { "required": ["food_product_name"] }
            ]
          }
        }
      }
    }
  }
}